APP_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Database
DATABASE_URL=postgres://user:password@host:5432/speakace
ADMIN_EMAILS=admin@example.com
TEACHER_EMAILS=teacher@example.com
EMAIL_FROM=SpeakAce <info@mail.speakace.org>
EMAIL_REPLY_TO=aa.arslan@outlook.com.tr
RESEND_API_KEY=re_...
EMAIL_LIFECYCLE_DAILY_BUDGET=20
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
OPENAI_FEEDBACK_MODEL=gpt-4o-mini
OPENAI_FEEDBACK_INPUT_USD_PER_1M=
OPENAI_FEEDBACK_OUTPUT_USD_PER_1M=
OPENAI_TRANSCRIBE_USD_PER_MINUTE=

# Analytics
NEXT_PUBLIC_ENABLE_ANALYTICS=true
ANALYTICS_ID_SALT=replace_with_a_long_random_string
MAINTENANCE_MODE=false

# Payments
LEMON_SQUEEZY_WEBHOOK_SECRET=whsec_...
LEMON_SQUEEZY_API_KEY=
LEMON_SQUEEZY_STORE_ID=
ENABLE_PRACTICE_LIMIT_RECOVERY_EMAILS=false
LEMON_SQUEEZY_STORE_URL=https://speakace.lemonsqueezy.com
GOOGLE_SITE_VERIFICATION=
ADMIN_PANEL_USERNAME=admin
ADMIN_PANEL_PASSWORD=change_me

# Cron / reminders
CRON_SECRET=replace_with_a_long_random_string

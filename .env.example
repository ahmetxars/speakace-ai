APP_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Database
DATABASE_URL=postgres://user:password@host:5432/speakace
ADMIN_EMAILS=admin@example.com
TEACHER_EMAILS=teacher@example.com
EMAIL_FROM=hello@speakace.org
EMAIL_REPLY_TO=support@speakace.org
RESEND_API_KEY=re_...
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
OPENAI_FEEDBACK_MODEL=gpt-4o-mini

# Analytics
NEXT_PUBLIC_ENABLE_ANALYTICS=true
MAINTENANCE_MODE=false

# Payments
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
LEMON_SQUEEZY_WEBHOOK_SECRET=whsec_...
LEMON_SQUEEZY_STORE_URL=https://speakace.lemonsqueezy.com
GOOGLE_SITE_VERIFICATION=
ADMIN_PANEL_USERNAME=admin
ADMIN_PANEL_PASSWORD=change_me

# Cron / reminders
CRON_SECRET=replace_with_a_long_random_string
